APP_NAME="Mail Forge"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_KEY=
FORCE_HTTPS=false

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mailforge
DB_USERNAME=root
DB_PASSWORD=
DB_PREFIX=mf_
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

MAIL_DRIVER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="Mail Forge"
MAIL_REPLYTO_ADDRESS=
MAIL_REPLYTO_NAME=
MAIL_TIMEOUT=30
MAIL_BATCH_SIZE=100
MAIL_BATCH_INTERVAL=10

SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

COMPANY_NAME="Your Company"
COMPANY_EMAIL=admin@example.com
DEFAULT_TIMEZONE=UTC
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=USD

PWA_NAME="Mail Forge"
PWA_SHORT_NAME="MailForge"
PWA_THEME_COLOR=#1a73e8
PWA_BG_COLOR=#ffffff

TRACKING_OPENS=true
TRACKING_CLICKS=true
DOUBLE_OPTIN=true
ENCRYPTION_KEY=