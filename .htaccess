Options -Indexes
Options +FollowSymLinks

# ─── Protect sensitive files and directories ──────────────────────────────────

# Block .env and other sensitive files
<FilesMatch "^(\.env.*|composer\.(json|lock)|package(-lock)?\.json|yarn\.lock)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block hidden files (starting with a dot) except .well-known
<FilesMatch "^\.(?!well-known)">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block direct access to sensitive directories
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block access to sensitive server-side directories (not install/ — the installer must be web-accessible)
    RewriteRule ^(app|config|database|storage|bootstrap|vendor|cron)(/|$) - [F,L]

    # ─── Static assets & front controller ────────────────────────────────────
    # Forward all requests that don't match a real file or directory to public/.
    # This works correctly in subdirectory installations (e.g. /mail/) because
    # it uses relative paths rather than %{DOCUMENT_ROOT}/public%{REQUEST_URI}.
    # After this rewrite, public/.htaccess routes non-files to public/index.php
    # which acts as the front controller.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L,QSA]

    # ─── Fallback front controller ────────────────────────────────────────────
    # If the public/ rewrite above did not resolve a file, route through the
    # root index.php front controller as a safety net.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# ─── Security headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
