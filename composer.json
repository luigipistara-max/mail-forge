{
    "name": "mail-forge/mail-forge",
    "description": "Mail Forge — self-hosted email marketing platform",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "phpmailer/phpmailer": "^6.8",
        "vlucas/phpdotenv": "^5.5",
        "ramsey/uuid": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "MailForge\\": "app/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('database/migrate.php') && passthru('php database/migrate.php');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
